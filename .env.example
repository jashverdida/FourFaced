# API key for the LLM endpoint. Default endpoint is the Gemini API's
# OpenAI-compatible layer (serves Gemma 4 serverless, free tier).
# Create one at https://aistudio.google.com -> Get API key.
# Never commit a real key.
GEMINI_API_KEY=

# Optional: point at a different OpenAI-compatible provider (e.g. Fireworks:
# https://api.fireworks.ai/inference/v1 with FIREWORKS_API_KEY set instead).
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# FIREWORKS_API_KEY=

# Model used for the vision-grounding stage (frames -> factual description).
GROUND_MODEL=gemma-4-31b-it

# Model used for the styling stage (factual description -> styled captions).
STYLE_MODEL=gemma-4-31b-it

# Per-clip wall-clock budget in seconds — the single source of truth for all
# timing decisions, in the container and the local UI alike (harness limit
# is 30; 27 leaves a 3s safety margin).
# PER_CLIP_BUDGET=27

# Frame-sampling ceiling (~4s cadence), tuned to the 27s budget. Raising it
# samples long clips more densely at the cost of clip-budget margin.
# MAX_FRAMES=15
